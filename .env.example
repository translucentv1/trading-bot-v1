# =============================================================================
# Vorlage fuer Zugangsdaten (Phase 2 - aktuell noch UNGENUTZT)
# =============================================================================
# So funktioniert es spaeter:
#   1. Diese Datei kopieren und die Kopie ".env" nennen.
#   2. In der Kopie die Platzhalter durch echte Werte ersetzen.
#   3. Die .env-Datei bleibt lokal - sie steht in .gitignore und darf
#      NIEMALS committet oder geteilt werden.
# In DIESE Vorlage gehoeren niemals echte Werte, nur Platzhalter.

# Broker-Zugangsdaten (welcher Broker: wird in Phase 2 entschieden)
BROKER_API_KEY=platzhalter-hier-spaeter-deinen-key-eintragen
BROKER_API_SECRET=platzhalter-hier-spaeter-dein-secret-eintragen

# Geheimnis, mit dem der Bot in Phase 2 pruefen wird, dass Webhook-Signale
# wirklich von TradingView kommen (frei waehlbare Zufallszeichenkette)
WEBHOOK_SECRET=platzhalter-zufaellige-zeichenkette
